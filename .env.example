# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#
#   cp .env.example .env
#
# This repository is PUBLIC. Only `.env.example` (placeholders) is committed;
# `.env`, `data/`, and `*.db` are git-ignored.

# --- Application ---
APP_ENV=development
LOG_LEVEL=info

# --- Ports ---
# 9990 = LINE webhook (FastAPI), 9991 = dashboard (NiceGUI)
WEBHOOK_PORT=9990
DASHBOARD_PORT=9991
APP_HOST=0.0.0.0

# --- LINE Messaging API credentials (from the LINE Developers Console) ---
# Channel secret: used to verify the X-Line-Signature header (HMAC-SHA256).
LINE_CHANNEL_SECRET=
# Channel access token: used as the Bearer token to reply / push / get profile.
LINE_CHANNEL_ACCESS_TOKEN=

# --- Behaviour ---
# Auto-echo each incoming text message back via the Reply API.
# Set to false for offline/local testing (a fake reply token would fail).
AUTO_REPLY=true

# --- Storage ---
DATABASE_URL=sqlite:///./data/line.db
# Secret used by NiceGUI for signed session cookies (any random string).
STORAGE_SECRET=change-me-to-a-random-string
